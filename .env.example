# ==============================================================================
# KBase Uploader — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to version control.

# --- KBase Authentication ---
# Your Google account email linked to your KBase account.
KBASE_EMAIL=your.email@gmail.com

# Your Google account password.
KBASE_PASSWORD=your_password_here

# --- Narrative Target ---
# The exact name of your KBase Narrative (as it appears on the Dashboard).
# Used to find and open the correct narrative automatically.
NARRATIVE=My Narrative Name

# --- File Paths ---
# Path to your input CSV file containing the FTP links.
KBASE_CSV_PATH=data.csv

# Directory to store the persistent browser session. Created automatically.
# Do NOT commit this directory to version control.
KBASE_USER_DIR=./kbase_user_session

# --- KBase Dashboard URL (usually does not need changing) ---
KBASE_DASHBOARD_URL=https://narrative.kbase.us/narratives
